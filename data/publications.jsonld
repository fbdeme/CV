  },

  "topics": [
    {
      "@id": "topic:medical-ai",
      "@type": "Topic",
      "name": "Medical AI",
      "description": "Multi-modal analysis combining EEG signals and natural language"
    },
    {
      "@id": "topic:llm-negotiation",
      "@type": "Topic",
      "name": "LLM Negotiation & Commerce",
      "description": "Strategic dialogue and behavioral simulation of LLMs in negotiation scenarios",
      "relatedTo": ["topic:conversational-agents"]
    },
    {
      "@id": "topic:knowledge-graph",
      "@type": "Topic",
      "name": "Knowledge Graph & QA",
      "description": "Graph-based reasoning and question answering over knowledge graphs",
      "relatedTo": ["topic:schema-matching"]
    },
    {
      "@id": "topic:schema-matching",
      "@type": "Topic",
      "name": "Schema Matching & Data Integration",
      "description": "KG-augmented schema alignment for heterogeneous data systems",
      "relatedTo": ["topic:knowledge-graph"]
    },
    {
      "@id": "topic:conversational-agents",
      "@type": "Topic",
      "name": "Conversational Agents",
      "description": "Emotion-aware and proactive dialogue systems",
      "relatedTo": ["topic:llm-negotiation"]
    },
    {
      "@id": "topic:text-summarization",
      "@type": "Topic",
      "name": "Text Summarization",
      "description": "Semantic pre-training methods for improving text summarization quality"
    }
  ],

